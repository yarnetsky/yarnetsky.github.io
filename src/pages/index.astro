---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import { withBase } from '../lib/url';

const allProjects = await getCollection('projects');
const projects = allProjects
  .sort((a, b) => {
    const byDate = b.data.publishDate.getTime() - a.data.publishDate.getTime();
    return byDate || (a.data.order ?? 999) - (b.data.order ?? 999);
  })
  .slice(0, 3);
const projectTags = [...new Set(allProjects.flatMap((project) => project.data.tags ?? []))].sort();

export async function getStaticPaths() {
  const entries = await getCollection('projects');
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}


// const posts = (await getCollection('blog'))
//   .filter((post) => !post.data.draft)
//   .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
//   .slice(0, 3);

const about = (await getCollection('about'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 4);

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('en', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  }).format(date);
---

<BaseLayout
  title="Jerry Yarnetsky, MLS"
  description="Draft portfolio. Web Services librarian at Miami University."
>
  <section class="hero section">
    <p class="eyebrow">Project / CV / Notes</p>
    <h1>Web Services Librarian at Miami University</h1>
    <p class="lead">
      User experience from digital accessibility and front-end development to usability testing and content wrangling.
    </p>
    <div class="action-row" aria-label="Primary links">
      <a class="button" href={withBase('/projects/')}>View my work</a>
      <!-- <a class="text-link" href={withBase('/blog/')}>Read notes</a>-->
      <a class="text-link" href={withBase('/about/')}>Read more about my experience, service, and scholarship</a>
    </div>
  </section>

 <!-- 
 <section class="section split-overview" aria-label="Theme overview">
    <div>
      <p class="eyebrow">Principles</p>
      <h2>Readable first, decorative last.</h2>
    </div>
    <div class="feature-list">
      <article>
        <h3>Baseline rhythm</h3>
        <p>Vertical spacing follows a steady cadence for long-form reading.</p>
      </article>
      <article>
        <h3>Typed content</h3>
        <p>Collections are prepared for project case studies and durable notes.</p>
      </article>
      <article>
        <h3>Keel lines</h3>
        <p>Fine rules create structure without relying on decorative effects.</p>
      </article>
    </div>
  </section>
-->

  <section class="section index-feed" aria-labelledby="latest-works">
    <div class="section-heading">
      <p class="eyebrow">Primary work, service, and scholarship work</p>
      <h2 id="latest-works">Latest Projects.</h2>

      {projectTags.length > 0 && (
        <ul class="tag-list" aria-label="Project tags">
          {projectTags.map((tag) => (
            <li><a href={withBase(`/projects/${tag}/`)}>{tag}</a></li>
          ))}
        </ul>
      )}

     <div class="action-row">
            <a class="text-link" href={withBase('/projects/')}>All Projects</a>
      <a class="text-link" href={withBase('/projects/Service/')}>Service Projects</a>
      <a class="text-link" href={withBase('/projects/Scholarship/')}>Scholarship</a>
     </div>
    </div>

    {
      projects.length > 0 ? (
        <div class="highlight-grid">
          {projects.map((project) => (
            <article class="highlight-card">
              {project.data.thumbnail && (
                <Image
                  src={project.data.thumbnail}
                  alt=""
                  width={720}
                  height={480}
                  loading="lazy"
                />
              )}
              <div>
                <p class="meta">{formatDate(project.data.publishDate)}</p>
                <h3>
                  <a href={withBase(`/projects/${project.id}/`)}>{project.data.title}</a>
                </h3>
                <p>{project.data.description}</p>
                {project.data.tags.length > 0 && (
                  <ul class="tag-list" aria-label={`${project.data.title} tags`}>
                    {project.data.tags.slice(0, 4).map((tag) => (
                      <li>{tag}</li>
                    ))}
                  </ul>
                )}
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="empty-state compact">
          <p>Add projects under <code>src/content/projects</code> to surface the latest projects here.</p>
        </div>
      )
    }
  </section>

  <section class="section index-feed" aria-labelledby="About">
    <div class="section-heading">
      <h2 id="about">About Me</h2>
      <a class="text-link" href={withBase('/about/')}>Read more</a>
    </div>

    {
      about.length > 0 ? (
        <div class="note-list">
          {about.map((post) => (
            <article class="note-row">
              {post.data.heroImage && (
                <Image
                  src={post.data.heroImage}
                  alt=""
                  width={320}
                  height={220}
                  loading="lazy"
                />
              )}
              <div>
                <p class="meta">{formatDate(post.data.publishDate)}</p>
                <h3>
                  <a href={withBase(`/about/${post.id}/`)}>{post.data.title}</a>
                </h3>
                <p>{post.data.description}</p>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="empty-state compact">
          <p>Add about entries under <code>src/content/about</code> to surface the latest information here.</p>
        </div>
      )
    }
  </section>


