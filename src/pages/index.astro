---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import { withBase } from '../lib/url';

const works = (await getCollection('works'))
  .sort((a, b) => {
    const byDate = b.data.publishDate.getTime() - a.data.publishDate.getTime();
    return byDate || (a.data.order ?? 999) - (b.data.order ?? 999);
  })
  .slice(0, 3);

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);

const about = (await getCollection('about'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('en', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  }).format(date);
---

<BaseLayout
  title="Jerry Yarnetsky, MLS"
  description="Draft portfolio. Web Services librarian at Miami University."
>
  <section class="hero section">
    <p class="eyebrow">Project / CV / Notes</p>
    <h1>Web Services Librarian at Miami University</h1>
    <p class="lead">
      User experience from digital accessibility and front-end development to usability testing and content wrangling.
    </p>
    <div class="action-row" aria-label="Primary links">
      <a class="button" href={withBase('/works/')}>View my work</a>
      <a class="text-link" href={withBase('/blog/')}>Read notes</a>
      <a class="text-link" href={withBase('/about/')}>About me</a>
    </div>
  </section>

 <!-- 
 <section class="section split-overview" aria-label="Theme overview">
    <div>
      <p class="eyebrow">Principles</p>
      <h2>Readable first, decorative last.</h2>
    </div>
    <div class="feature-list">
      <article>
        <h3>Baseline rhythm</h3>
        <p>Vertical spacing follows a steady cadence for long-form reading.</p>
      </article>
      <article>
        <h3>Typed content</h3>
        <p>Collections are prepared for project case studies and durable notes.</p>
      </article>
      <article>
        <h3>Keel lines</h3>
        <p>Fine rules create structure without relying on decorative effects.</p>
      </article>
    </div>
  </section>
-->

  <section class="section index-feed" aria-labelledby="latest-works">
    <div class="section-heading">
      <p class="eyebrow">Latest works</p>
      <h2 id="latest-works">Built records.</h2>
      <a class="text-link" href={withBase('/works/')}>All works</a>
    </div>

    {
      works.length > 0 ? (
        <div class="highlight-grid">
          {works.map((work) => (
            <article class="highlight-card">
              {work.data.thumbnail && (
                <Image
                  src={work.data.thumbnail}
                  alt=""
                  width={720}
                  height={480}
                  loading="lazy"
                />
              )}
              <div>
                <p class="meta">{formatDate(work.data.publishDate)}</p>
                <h3>
                  <a href={withBase(`/works/${work.id}/`)}>{work.data.title}</a>
                </h3>
                <p>{work.data.description}</p>
                {work.data.tech.length > 0 && (
                  <ul class="tag-list" aria-label={`${work.data.title} technology`}>
                    {work.data.tech.slice(0, 4).map((tech) => (
                      <li>{tech}</li>
                    ))}
                  </ul>
                )}
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="empty-state compact">
          <p>Add works under <code>src/content/works</code> to surface the latest projects here.</p>
        </div>
      )
    }
  </section>

  <section class="section index-feed" aria-labelledby="About">
    <div class="section-heading">
      <h2 id="about">About Me</h2>
      <a class="text-link" href={withBase('/about/')}>Read more</a>
    </div>

    {
      about.length > 0 ? (
        <div class="note-list">
          {about.map((post) => (
            <article class="note-row">
              {post.data.heroImage && (
                <Image
                  src={post.data.heroImage}
                  alt=""
                  width={320}
                  height={220}
                  loading="lazy"
                />
              )}
              <div>
                <p class="meta">{formatDate(post.data.publishDate)}</p>
                <h3>
                  <a href={withBase(`/about/${post.id}/`)}>{post.data.title}</a>
                </h3>
                <p>{post.data.description}</p>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="empty-state compact">
          <p>Add about entries under <code>src/content/about</code> to surface the latest information here.</p>
        </div>
      )
    }
  </section>


<section class="section index-feed" aria-labelledby="latest-notes">
    <div class="section-heading">
      <p class="eyebrow">Latest blog</p>
      <h2 id="latest-notes">Field notes.</h2>
      <a class="text-link" href={withBase('/blog/')}>All posts</a>
    </div>

    {
      posts.length > 0 ? (
        <div class="note-list">
          {posts.map((post) => (
            <article class="note-row">
              {post.data.heroImage && (
                <Image
                  src={post.data.heroImage}
                  alt=""
                  width={320}
                  height={220}
                  loading="lazy"
                />
              )}
              <div>
                <p class="meta">{formatDate(post.data.publishDate)}</p>
                <h3>
                  <a href={withBase(`/blog/${post.id}/`)}>{post.data.title}</a>
                </h3>
                <p>{post.data.description}</p>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="empty-state compact">
          <p>Add blog entries under <code>src/content/blog</code> to surface the latest notes here.</p>
        </div>
      )
    }
  </section>


</BaseLayout>
