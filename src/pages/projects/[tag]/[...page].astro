---
import { getCollection } from 'astro:content';
import type { GetStaticPaths, InferGetStaticPropsType } from 'astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Pagination from '../../../components/Pagination.astro';
import { withBase } from '../../../lib/url';

export const getStaticPaths = (async ({ paginate }) => {
  const projects = await getCollection('projects');
  const allTags = [...new Set(projects.flatMap((project) => project.data.tags))].sort((a, b) => a.localeCompare(b));
  return allTags.flatMap((tag) => {
    const taggedProjects = projects
      .filter((project) => project.data.tags.includes(tag))
      .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
    const otherTags = allTags.filter((item) => item !== tag);
    return paginate(taggedProjects, { params: { tag }, pageSize: 10, props: { otherTags } });
  });
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { tag } = Astro.params;
const { page, otherTags } = Astro.props;
const taggedProjects = page.data;

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('en', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  }).format(date);

const pageTitle =
  page.currentPage === 1
    ? `Projects tagged "${tag}"`
    : `Projects tagged "${tag}" · Page ${page.currentPage}`;
---

<BaseLayout title={pageTitle} description={`Projects tagged ${tag}.`}>
  <section class="page-head section">
    <p class="eyebrow">Tag</p>
    <h1>{tag}</h1>
    <p class="lead">Projects collected under the {tag} tag.</p>
  </section>

  <section class="section content-index" aria-label={`${tag} projects`}>
    <div class="index-sidebar">
      <p class="eyebrow">More tags</p>
      <nav class="tag-cloud" aria-label="Other project tags">
        <a href={withBase('/projects/')}>All projects</a>
        {otherTags.map((item) => <a href={withBase(`/projects/${item}/`)}>{item}</a>)}
      </nav>
    </div>

    <div>
      <div class="entry-list">
        {
          taggedProjects.map((project) => (
            <article class="entry-card">
              <div class="entry-meta">
                <time datetime={project.data.publishDate.toISOString()}>{formatDate(project.data.publishDate)}</time>
                {project.data.tags.length > 0 && (
                  <ul class="tag-list" aria-label={`${project.data.title} tags`}>
                    {project.data.tags.map((t) => (
                      <li><a href={withBase(`/projects/${t}/`)}>{t}</a></li>
                    ))}
                  </ul>
                )}
              </div>
              <h2><a href={withBase(`/projects/${project.id}/`)}>{project.data.title}</a></h2>
              <p>{project.data.description}</p>
            </article>
          ))
        }
      </div>
      <Pagination page={page} />
    </div>
  </section>
</BaseLayout>
